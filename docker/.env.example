# Image tag (matches docker compose `image:` line)
VERSION=latest

# Docker Hub image name (set to pull from registry instead of building locally)
# Example: IMAGE=jevonsnotes/lite-alert:1.0.0
# When set, docker compose pulls IMAGE directly; `image:` in compose resolves to this value.
IMAGE=

# Host port to expose
PORT=8080

# ---- secrets — change all three before running in production ----

# Jasypt master password used to decrypt ENC(...) values in application.yml
JASYPT_ENCRYPTOR_PASSWORD=please-change-me-32-char-min

# JWT signing secret (HS256) — must be at least 32 chars
LITE_ALERT_JWT_SECRET=please-change-me-and-keep-secret-32-chars-min

# Pepper used to derive ApiKey hashes — once set, NEVER rotate
# (rotating invalidates every existing ApiKey)
LITE_ALERT_APIKEY_PEPPER=please-change-me-and-never-rotate-without-migration

# ===================================================================
# Database configuration — pick ONE section below and uncomment it.
# By default the service uses H2 file database; no extra config needed.
# ===================================================================

# ---- Default: H2 (no changes required) ----
# LITE_ALERT_DATASOURCE_URL=
# LITE_ALERT_DATASOURCE_USERNAME=
# LITE_ALERT_DATASOURCE_PASSWORD=
# LITE_ALERT_DATASOURCE_DRIVER=
# LITE_ALERT_DATABASE_TYPE=

# ---- MySQL (run: docker compose --profile mysql up -d) ----
# LITE_ALERT_DATASOURCE_URL=jdbc:mysql://mysql:3306/lite_alert?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&createDatabaseIfNotExist=true
# LITE_ALERT_DATASOURCE_USERNAME=root
# LITE_ALERT_DATASOURCE_PASSWORD=litealert
# LITE_ALERT_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver
# LITE_ALERT_DATABASE_TYPE=mysql
# MYSQL_ROOT_PASSWORD=litealert
# MYSQL_PORT=3306

# ---- PostgreSQL (run: docker compose --profile postgres up -d) ----
# LITE_ALERT_DATASOURCE_URL=jdbc:postgresql://postgres:5432/lite_alert
# LITE_ALERT_DATASOURCE_USERNAME=postgres
# LITE_ALERT_DATASOURCE_PASSWORD=litealert
# LITE_ALERT_DATASOURCE_DRIVER=org.postgresql.Driver
# LITE_ALERT_DATABASE_TYPE=postgresql
# POSTGRES_PASSWORD=litealert
# POSTGRES_PORT=5432

# ---- GaussDB (uses PostgreSQL protocol, supply your own host) ----
# LITE_ALERT_DATASOURCE_URL=jdbc:postgresql://your-gaussdb-host:5432/lite_alert
# LITE_ALERT_DATASOURCE_USERNAME=your-gaussdb-user
# LITE_ALERT_DATASOURCE_PASSWORD=your-gaussdb-password
# LITE_ALERT_DATASOURCE_DRIVER=org.postgresql.Driver
# LITE_ALERT_DATABASE_TYPE=gaussdb

# ---- OceanBase (uses MySQL protocol, supply your own host) ----
# LITE_ALERT_DATASOURCE_URL=jdbc:mysql://your-oceanbase-host:2881/lite_alert?useSSL=false&serverTimezone=Asia/Shanghai&createDatabaseIfNotExist=true
# LITE_ALERT_DATASOURCE_USERNAME=root@litealert
# LITE_ALERT_DATASOURCE_PASSWORD=your-oceanbase-password
# LITE_ALERT_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver
# LITE_ALERT_DATABASE_TYPE=oceanbase
